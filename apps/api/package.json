{
  "name": "@sekiro/api",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "pnpm --filter @sekiro/shared build && tsc",
    "start": "node dist/main.js",
    "typecheck": "pnpm --filter @sekiro/shared build && tsc --noEmit",
    "encrypt:config": "tsx src/modules/security/cli/encrypt-config.cli.ts",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset-passwords": "tsx prisma/reset-passwords.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/nestjs-api-reference": "^1.2.8",
    "@sekiro/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "file-type": "^20.0.0",
    "helmet": "^8.0.0",
    "pg": "^8.22.0",
    "qrcode": "^1.5.3",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.8",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "prisma": "^7.8.0",
    "supertest": "^7.1.0",
    "tsx": "^4.23.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  }
}

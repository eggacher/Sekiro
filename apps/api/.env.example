# 复制为 .env 并按需修改。本地 docker-compose 已用 sekiro/sekiro123
# 应用查询用 DATABASE_URL；迁移用 DIRECT_DATABASE_URL（避开连接池限制）
DATABASE_URL="postgresql://sekiro:sekiro123@localhost:5432/sekiro?schema=public"
DIRECT_DATABASE_URL="postgresql://sekiro:sekiro123@localhost:5432/sekiro?schema=public"

# 接口限流（秒 / 次数）
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# 文件上传
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/*,application/pdf

# 配置加密（32 字节 base64 或 hex；用于解密 ENC(...) 环境变量）
CONFIG_ENCRYPTION_KEY=
